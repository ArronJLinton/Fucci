# API base URL (no trailing slash). Required for auth and data.
# Example: http://localhost:8080/v1
# Production: https://your-api.fly.dev/v1
EXPO_PUBLIC_API_URL=http://localhost:8080/v1

# Note: JWT_SECRET is used by the backend (services/api) only, not by the mobile app.
# See specs/005-user-registration-settings/quickstart.md for API environment setup.
