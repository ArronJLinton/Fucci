{
  "expo": {
    "name": "Fucci",
    "slug": "fucci",
    "scheme": "fucci",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magistridev.fucci",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Fucci to access your camera to take profile photos.",
        "NSPhotoLibraryUsageDescription": "Allow Fucci to access your photo library to choose profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.magistridev.fucci",
      "versionCode": 4,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0f172a",
          "resizeMode": "cover",
          "imageWidth": 1284
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take photos and record videos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fucci to access your photos so you can choose profile pictures.",
          "cameraPermission": "Allow Fucci to use your camera so you can take profile pictures."
        }
      ]
    ],
    "extra": {
      "APP_ENV": "development",
      "API_DEV_URL": "http://localhost:8080/v1/api",
      "API_STAGING_URL": "https://fucci-api.fly.dev/v1/api",
      "API_BASE_URL": "http://localhost:8080/v1/api",
      "APP_NAME": "Fucci",
      "APP_VERSION": "1.1.0",
      "NODE_ENV": "development",
      "DEBUG": "true",
      "releaseOwnership": {
        "accountModel": "organization-owned",
        "androidPackage": "com.magistridev.fucci",
        "iosBundleIdentifier": "com.magistridev.fucci"
      },
      "eas": {
        "projectId": "c02a1675-224d-4ac5-bdb6-2ed00ff33963"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c02a1675-224d-4ac5-bdb6-2ed00ff33963"
    }
  }
}