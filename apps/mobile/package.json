{
  "name": "fucciexpo",
  "version": "1.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "env:dev": "node scripts/set-env.js development",
    "env:staging": "node scripts/set-env.js staging",
    "env:prod": "node scripts/set-env.js production",
    "dev": "yarn env:dev && expo start",
    "dev:android": "yarn env:dev && expo start --android",
    "dev:ios": "yarn env:dev && expo start --ios",
    "staging": "yarn env:staging && expo start",
    "prod": "yarn env:prod && expo start",
    "build:android": "yarn env:prod && eas build -p android --profile production",
    "build:android-preview": "yarn env:staging && eas build -p android --profile preview",
    "build:ios": "yarn env:prod && eas build -p ios --profile production",
    "build:ios-staging": "yarn env:staging && eas build -p ios --profile preview",
    "build:ios-preview": "yarn env:staging && npx eas-cli build -p ios --profile preview",
    "preflight:typecheck": "yarn type-check",
    "preflight:doctor": "npx expo-doctor",
    "preflight:eas": "npx eas-cli whoami",
    "preflight:release": "yarn preflight:typecheck && yarn preflight:doctor && yarn preflight:eas",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules && yarn install",
    "reset": "yarn clean && yarn env:dev"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/material-top-tabs": "^7.3.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "@react-navigation/stack": "^7.4.8",
    "@tanstack/react-query": "^5.90.10",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fast-image"
        ]
      }
    }
  },
  "private": true
}
