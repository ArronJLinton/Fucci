# Database configuration
DB_URL=postgres://postgres:postgres@localhost:5432/fucci_api?sslmode=disable

# Server configuration
PORT=8080

# API Keys
FOOTBALL_API_KEY=your_api_key_here

# Cloudinary (008 photo upload)
# Used by POST /v1/api/upload/cloudinary/signature
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional unsigned preset (if used instead of signed uploads)
CLOUDINARY_UPLOAD_PRESET=

REDIS_SERVER_URL=