# Database configuration
DB_URL=postgres://postgres:postgres@localhost:5432/fucci_api?sslmode=disable

# Server configuration
PORT=8080

# API Keys
FOOTBALL_API_KEY=your_api_key_here

# Realtime news (Open Web Ninja / X-API-Key). If unset, RAPID_API_KEY is used.
NEWS_API_KEY=

# RapidAPI — for Google News (RapidAPI host).
RAPID_API_KEY=

# YouTube Data API v3 — team Shorts on match details (World Cup channel registry).
YOUTUBE_API_KEY=
# Redis TTL for youtube:shorts:* cache keys (hours; default 24).
YOUTUBE_CACHE_TTL_HOURS=24

# Expo push notifications (Phase 1)
EXPO_ACCESS_TOKEN=

# Cloudinary (008 photo upload)
# Used by POST /v1/api/upload/cloudinary/signature
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional unsigned preset (if used instead of signed uploads)
CLOUDINARY_UPLOAD_PRESET=

REDIS_URL=